<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<AssignMessage continueOnError="false" enabled="true" name="AM-401Unauthorized">
  <Set>
    <Payload contentType="application/json">{"statusCode":"4010","statusMessage":"Unauthorized","supportMessage":"Invalid or missing access token","transactionId":"{request.header.transactionId}","timestamp":"{system.timestamp}","path":"{request.uri}","method":"{request.verb}"}</Payload>
    <StatusCode>401</StatusCode>
    <ReasonPhrase>Unauthorized</ReasonPhrase>
  </Set>
  <IgnoreUnresolvedVariables>true</IgnoreUnresolvedVariables>
  <AssignTo createNew="false" transport="http" type="response"/>
</AssignMessage>