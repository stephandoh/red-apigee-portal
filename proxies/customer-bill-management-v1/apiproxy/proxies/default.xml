<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<ProxyEndpoint name="default">
    <Description>Customer Bill Management Proxy Endpoint</Description>
    <FaultRules>
        <FaultRule name="OAuthFault">
            <Condition>(fault.name = "InvalidAccessToken") or (fault.name = "InvalidApiKey") or (fault.name = "FailedToResolveAPIKey") or (fault.name = "invalid_access_token") or (fault.name = "access_token_expired") or (fault.name = "InvalidClientIdentifier")</Condition>
            <Step><Name>AM-401Unauthorized</Name></Step>
        </FaultRule>
        <FaultRule name="DefaultFault">
            <Condition>not ((fault.name = "InvalidAccessToken") or (fault.name = "InvalidApiKey") or (fault.name = "FailedToResolveAPIKey") or (fault.name = "invalid_access_token") or (fault.name = "access_token_expired") or (fault.name = "InvalidClientIdentifier") or (fault.name = "RaiseFault"))</Condition>
            <Step><Name>AM-DefaultFaultResponse</Name></Step>
        </FaultRule>
    </FaultRules>
    <PreFlow name="PreFlow">
        <Request>
            <Step><Name>FC-SecurityCommon</Name></Step>
        </Request>
        <Response/>
    </PreFlow>
    <PostFlow name="PostFlow">
        <Request/>
        <Response/>
    </PostFlow>
    <Flows>
        <Flow name="GetCustomerBillById">
            <Description>Retrieves a CustomerBill by ID</Description>
            <Request/>
            <Response>
                <Step><Name>AM-GetCustomerBillById</Name></Step>
            </Response>
            <Condition>(proxy.pathsuffix JavaRegex "/[^/]+") and (request.verb = "GET")</Condition>
        </Flow>
        <Flow name="GetCustomerBill">
            <Description>List or find CustomerBills</Description>
            <Request/>
            <Response>
                <Step><Name>AM-GetCustomerBill</Name></Step>
            </Response>
            <Condition>request.verb = "GET"</Condition>
        </Flow>
        <Flow name="UnknownRequest">
            <Description>Catch all unknown requests</Description>
            <Request>
                <Step><Name>RF-404NotFound</Name></Step>
            </Request>
            <Response/>
        </Flow>
    </Flows>
    <HTTPProxyConnection>
        <BasePath>/customer/bill/v1</BasePath>
    </HTTPProxyConnection>
    <RouteRule name="NoRoute"/>
</ProxyEndpoint>
