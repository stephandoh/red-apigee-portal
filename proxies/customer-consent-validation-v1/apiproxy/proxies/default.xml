<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<ProxyEndpoint name="default">
  <Description/>
  <FaultRules>
    <FaultRule name="DefaultFault">
      <Step><Name>AM-DefaultFaultResponse</Name></Step>
    </FaultRule>
  </FaultRules>
  <PreFlow name="PreFlow">
    <Request>
      <Step><Name>FC-SecurityCommon</Name></Step>
    </Request>
    <Response/>
  </PreFlow>
  <PostFlow name="PostFlow">
    <Request/>
    <Response/>
  </PostFlow>
  <Flows>
    <Flow name="createPreapproval">
      <Description>Create preapproval — must be before consent/{msisdn}</Description>
      <Request>
        <Step><Name>JSONTP-RequestBodyProtection</Name></Step>
      </Request>
      <Response>
        <Step><Name>AM-Mock-CreatePreapproval</Name></Step>
      </Response>
      <Condition>(proxy.pathsuffix MatchesPath "/consent/preapproval") and (request.verb = "POST")</Condition>
    </Flow>
    <Flow name="cancelPreapproval">
      <Description>Cancel preapproval — must be before consent/{msisdn}</Description>
      <Request>
        <Step><Name>JSONTP-RequestBodyProtection</Name></Step>
      </Request>
      <Response>
        <Step><Name>AM-Mock-CancelPreapproval</Name></Step>
      </Response>
      <Condition>(proxy.pathsuffix MatchesPath "/consent/cancelPreapproval") and (request.verb = "POST")</Condition>
    </Flow>
    <Flow name="consentValidation">
      <Description>Consent validation by MSISDN</Description>
      <Request>
        <Step><Name>RegexTP-ValidateMSISDN</Name></Step>
        <Step><Name>JSONTP-RequestBodyProtection</Name></Step>
      </Request>
      <Response>
        <Step><Name>AM-Mock-ConsentValidation</Name></Step>
      </Response>
      <Condition>(proxy.pathsuffix MatchesPath "/consent/*") and (request.verb = "POST") and not (proxy.pathsuffix MatchesPath "/consent/*/generateotp") and not (proxy.pathsuffix MatchesPath "/consent/*/verifyotp")</Condition>
    </Flow>
    <Flow name="generateOTP">
      <Description>Generate OTP for customer</Description>
      <Request>
        <Step><Name>RegexTP-ValidateMSISDN</Name></Step>
        <Step><Name>JSONTP-RequestBodyProtection</Name></Step>
      </Request>
      <Response>
        <Step><Name>AM-Mock-GenerateOTP</Name></Step>
      </Response>
      <Condition>(proxy.pathsuffix MatchesPath "/consent/*/generateotp") and (request.verb = "POST")</Condition>
    </Flow>
    <Flow name="verifyOTP">
      <Description>Verify OTP for customer</Description>
      <Request>
        <Step><Name>RegexTP-ValidateMSISDN</Name></Step>
      </Request>
      <Response>
        <Step><Name>AM-Mock-VerifyOTP</Name></Step>
      </Response>
      <Condition>(proxy.pathsuffix MatchesPath "/consent/*/verifyotp") and (request.verb = "POST")</Condition>
    </Flow>
    <Flow name="404NotFound">
      <Description>Catch all unmatched paths</Description>
      <Request>
        <Step><Name>RF-404NotFound</Name></Step>
      </Request>
      <Response/>
    </Flow>
  </Flows>
  <HTTPProxyConnection>
    <BasePath>/customer/consent/v1</BasePath>
    <Properties/>
  </HTTPProxyConnection>
  <RouteRule name="NoRoute">
    <Condition>true == false</Condition>
  </RouteRule>
</ProxyEndpoint>
