<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<ProxyEndpoint name="default">
  <Description/>
  <FaultRules>
    <FaultRule name="OAuthFault">
      <Condition>(fault.name = "InvalidAccessToken") or (fault.name = "InvalidApiKey") or (fault.name = "FailedToResolveAPIKey") or (fault.name = "invalid_access_token") or (fault.name = "access_token_expired") or (fault.name = "InvalidClientIdentifier")</Condition>
      <Step><Name>AM-401Unauthorized</Name></Step>
    </FaultRule>
    <FaultRule name="DefaultFault">
      <Condition>not ((fault.name = "InvalidAccessToken") or (fault.name = "InvalidApiKey") or (fault.name = "FailedToResolveAPIKey") or (fault.name = "invalid_access_token") or (fault.name = "access_token_expired") or (fault.name = "InvalidClientIdentifier") or (fault.name = "RaiseFault"))</Condition>
      <Step><Name>AM-DefaultFaultResponse</Name></Step>
    </FaultRule>
  </FaultRules>
  <PreFlow name="PreFlow">
    <Request>
      <Step><Name>FC-SecurityCommon</Name></Step>
    </Request>
    <Response/>
  </PreFlow>
  <PostFlow name="PostFlow">
    <Request/>
    <Response/>
  </PostFlow>
  <Flows>
    <Flow name="getAccountholderProfile">
      <Description>Get accountholder profile by MSISDN</Description>
      <Request>
        <Step><Name>RegexTP-ValidateMSISDN</Name></Step>
      </Request>
      <Response>
        <Step><Name>AM-Mock-AccountholderProfile</Name></Step>
      </Response>
      <Condition>(proxy.pathsuffix MatchesPath "/accountholders/*") and (request.verb = "GET") and not (proxy.pathsuffix MatchesPath "/accountholders/*/validate") and not (proxy.pathsuffix MatchesPath "/accountholders/*/verify")</Condition>
    </Flow>
    <Flow name="validateAccountholder">
      <Description>Validate accountholder status</Description>
      <Request>
        <Step><Name>RegexTP-ValidateMSISDN</Name></Step>
      </Request>
      <Response>
        <Step><Name>AM-Mock-ValidateAccountholder</Name></Step>
      </Response>
      <Condition>(proxy.pathsuffix MatchesPath "/accountholders/*/validate") and (request.verb = "GET")</Condition>
    </Flow>
    <Flow name="verifyAccountholder">
      <Description>Verify financial resources</Description>
      <Request>
        <Step><Name>RegexTP-ValidateMSISDN</Name></Step>
        <Step><Name>JSONTP-RequestBodyProtection</Name></Step>
      </Request>
      <Response>
        <Step><Name>AM-Mock-VerifyAccountholder</Name></Step>
      </Response>
      <Condition>(proxy.pathsuffix MatchesPath "/accountholders/*/verify") and (request.verb = "POST")</Condition>
    </Flow>
    <Flow name="404NotFound">
      <Description>Catch all unmatched paths</Description>
      <Request>
        <Step><Name>RF-404NotFound</Name></Step>
      </Request>
      <Response/>
    </Flow>
  </Flows>
  <HTTPProxyConnection>
    <BasePath>/customer/accountholders/v1</BasePath>
    <Properties/>
  </HTTPProxyConnection>
  <RouteRule name="NoRoute"/>
</ProxyEndpoint>
